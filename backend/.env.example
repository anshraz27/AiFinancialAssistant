# Environment Mode
NODE_ENV=development
PORT=5000

# Databases and Cache
# Local: mongodb://localhost:27017/finscope
# Production: Use MongoDB Atlas connection string
MONGODB_URI=mongodb://localhost:27017/finscope

# Local: redis://localhost:6379
# Production: Use Upstash Redis URL (rediss:// for TLS)
REDIS_URL=redis://localhost:6379

# Security
JWT_SECRET=your_jwt_secret_here

# Frontend Integration
# Local: http://localhost:5173
# Production: Your Vercel deployment URL (e.g. https://finscope.vercel.app)
FRONTEND_URL=http://localhost:5173

# Email Configuration
EMAIL_SERVICE=gmail
EMAIL_USER=your_email_here@gmail.com
EMAIL_PASS=your_email_app_password_here
