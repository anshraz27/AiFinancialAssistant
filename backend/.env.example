# .env.example
NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://localhost:27017/finscope
JWT_SECRET=your_jwt_secret_here
FRONTEND_URL=http://localhost:3000

REDIS_URL=redis://localhost:6379
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# AWS S3 Configuration (for receipt image storage)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your_bucket_name

# Hugging Face VLM Configuration (OpenAI-compatible endpoint)
HF_API_URL=https://your-hf-endpoint/v1
HF_API_KEY=your_hf_api_key
HF_MODEL_NAME=Qwen/Qwen2.5-VL-7B-Instruct
